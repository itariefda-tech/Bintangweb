# Copy to .env and change the password before production deployment.
OWNER_PASSWORD=owner1380

# Member session defaults: 8 hours idle, 7 days absolute.
MEMBER_SESSION_TTL=28800
MEMBER_SESSION_ABSOLUTE_TTL=604800

# Comma-separated emails registered as super_admin.
MARKETPLACE_SUPER_ADMIN_EMAILS=owner@example.com

# Password reset email. Enable debug only for local development.
PASSWORD_RESET_DEBUG=0
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=1

# Midtrans Core API. Keep mock enabled until sandbox credentials are ready.
MIDTRANS_MOCK=1
MIDTRANS_SERVER_KEY=
MIDTRANS_PRODUCTION=0
